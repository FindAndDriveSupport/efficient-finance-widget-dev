# E-fficient Finance Widget — Environment Variables
# Copy to .env and fill in values before running.

# Worker base URL (no trailing slash)
VITE_WORKER_URL=https://api.yourwidgetdomain.co.za

# Optional: Mixpanel project token (omit to disable analytics)
VITE_MIXPANEL_TOKEN=

# Embed params are read from the URL query string at runtime — do not hard-code:
# ?dealer=findndrive
# ?make=Toyota
# ?model=Corolla
# ?mm=12345678
# ?branch=FND001
