name: Sync from Dev

on:
  repository_dispatch:
    types: [sync-from-dev]
  workflow_dispatch:

jobs:
  sync:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout template repo (e-fficient-ui)
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.GH_PAT }}
          path: template

      - name: Checkout dev repo (e-fficient-ui-dev)
        uses: actions/checkout@v4
        with:
          repository: FindAndDriveSupport/e-fficient-ui-dev
          token: ${{ secrets.GH_PAT }}
          path: dev

      - name: Sync files from dev to template
        run: |
          rsync -av --delete \
            --exclude='.git/' \
            --exclude='node_modules/' \
            --exclude='.env' \
            --exclude='wrangler.toml' \
            --exclude='src/config/dealerConfig.ts' \
            --exclude='src/contexts/DealerContext.tsx' \
            --exclude='src/routes/index.tsx' \
            --exclude='.github/' \
            dev/ template/

      - name: Check for changes
        id: changes
        run: |
          cd template
          git diff --quiet && echo "changed=false" >> $GITHUB_OUTPUT || echo "changed=true" >> $GITHUB_OUTPUT

      - name: Commit and push changes
        if: steps.changes.outputs.changed == 'true'
        run: |
          cd template
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add -A
          git commit -m "chore: sync latest changes from e-fficient-ui-dev"
          git push